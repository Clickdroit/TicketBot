# 🎫 TicketBot - Configuration des variables d'environnement

# Token de votre bot Discord (obtenu sur le portail développeur de Discord)
DISCORD_TOKEN=votre_token_ici

# URL de connexion à la base de données.
# - SQLite par défaut : jdbc:sqlite:data/ticketbot.db
# - PostgreSQL / Supabase : postgresql://user:password@host:port/dbname
DATABASE_URL=jdbc:sqlite:data/ticketbot.db
